{
  "name": "node-complete",
  "version": "1.0.0",
  "description": "Complete Node.js project for Brik E2E testing with Nexus publish",
  "main": "src/index.js",
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --outfile=dist/index.js --minify",
