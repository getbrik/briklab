# Briklab - Environment variables
# Copy to .env and customize before first start

# === GitLab ===
GITLAB_ROOT_PASSWORD=Brik-Gtlb-2026
GITLAB_HTTP_PORT=8929
GITLAB_SSH_PORT=2222
GITLAB_HOSTNAME=gitlab.briklab.test
# Max concurrent jobs the runner can execute in parallel (default: 4)
GITLAB_RUNNER_CONCURRENT=4
# How many jobs the runner requests from GitLab simultaneously (default: same as concurrent)
# GITLAB_RUNNER_REQUEST_CONCURRENCY=4
# Memory limit per CI job container (default: 512m)
# GITLAB_RUNNER_JOB_MEMORY=512m
# Automatically generated by ./scripts/briklab.sh setup:
GITLAB_PAT=
GITLAB_RUNNER_TOKEN=

# === Docker Registry ===
REGISTRY_PORT=5050
REGISTRY_HOSTNAME=registry.briklab.test

# === Gitea ===
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=222
GITEA_HOSTNAME=gitea.briklab.test
GITEA_ADMIN_PASSWORD=Brik-Gitea-2026
# Automatically generated by ./scripts/briklab.sh setup:
GITEA_PAT=

# === Jenkins ===
JENKINS_HTTP_PORT=9090
JENKINS_AGENT_PORT=50000
JENKINS_HOSTNAME=jenkins.briklab.test
JENKINS_ADMIN_PASSWORD=Brik-Jenkins-2026

# === Nexus ===
NEXUS_HOSTNAME=nexus.briklab.test
NEXUS_HTTP_PORT=8081
NEXUS_DOCKER_PORT=8082
NEXUS_ADMIN_PASSWORD=Brik-Nexus-2026
# Automatically generated by ./scripts/briklab.sh setup:
NEXUS_NPM_TOKEN=

# === k3d / ArgoCD ===
K3D_API_PORT=6443
K3D_HTTP_PORT=8080
# Memory allocated to k3d server and agent nodes (default: 4g)
K3D_SERVER_MEMORY=4g
K3D_AGENT_MEMORY=4g
ARGOCD_PORT=9080
ARGOCD_HOSTNAME=argocd.briklab.test
# Automatically generated by ./scripts/briklab.sh setup:
ARGOCD_ADMIN_PASSWORD=

# === Docker Network ===
DOCKER_NETWORK=brik-net
DOCKER_SUBNET=172.20.0.0/16
